# Environment variables consumed by /api/signup in Iter 19.
# Set these in Vercel Project Settings → Environment Variables before
# enabling the orchestration logic.

# Keygen.io — license provisioning
KEYGEN_ACCOUNT_ID=
KEYGEN_ADMIN_TOKEN=
KEYGEN_TRIAL_POLICY_ID=

# GitHub App — auto-invite customers to the cc-testframework repo
GH_APP_ID=
GH_APP_PRIVATE_KEY=
GH_APP_INSTALLATION_ID=
GH_ORG=meinTest
GH_REPO=cc-testframework

# Resend — transactional email
RESEND_API_KEY=
RESEND_FROM=noreply@itsbusiness.ch

# Sales handoff
SALES_NOTIFY_EMAIL=sales@itsbusiness.ch
