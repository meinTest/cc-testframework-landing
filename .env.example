# Environment variables for the cc-testframework landing page.
# Set in Vercel Project Settings → Environment Variables.

# --- Feature flags ---
# Master kill-switch. When not "true", /signup renders the disclaimer
# and /api/signup returns 503.
SIGNUP_ENABLED=false

# When "true", all external API calls (Keygen, GitHub, Resend) are
# logged but not executed. Endpoint returns mock success.
DRY_RUN=true

# Sales-vetted onboarding gate. When "true": hero CTA points to
# /demo-request, /signup without ?token=<X> shows a token-required
# error, and /api/signup enforces token validation. When "false" (or
# unset), the open flow stays active — /signup is directly reachable.
SALES_VETTED_MODE=true

# --- Keygen.io ---
KEYGEN_ACCOUNT_ID=
KEYGEN_ADMIN_TOKEN=
KEYGEN_TRIAL_POLICY_ID=
# Policy for the sales-issued "pending" licenses that act as
# single-use signup tokens. Must NOT be treated as a valid trial
# by the runtime license check.
KEYGEN_PENDING_POLICY_ID=

# --- Sales gate ---
# Bearer token guarding /api/sales/* endpoints. Generate via
# `openssl rand -hex 32` and keep in the password manager.
# Also doubles as the Basic-Auth password for the /sales admin UI
# (username is hard-coded to "sales").
SALES_API_KEY=
# Inbox receiving demo-request notifications. Stays on support@
# until sales@ is provisioned.
SALES_NOTIFY_EMAIL=support@itsbusiness.ch

# --- GitHub App ---
# Number, e.g. 1234567
GH_APP_ID=
# Multi-line PEM. In Vercel use the multi-line input mode.
# When provided as a single line, use \n as escape; the code
# normalizes it back to real newlines.
GH_APP_PRIVATE_KEY=
GH_APP_INSTALLATION_ID=
GH_ORG=meinTest
GH_REPO=cc-testframework

# --- Resend ---
RESEND_API_KEY=
# Sandbox until itsbusiness.ch domain is verified.
RESEND_FROM=cc-testframework <onboarding@resend.dev>
RESEND_SUPPORT_TO=support@itsbusiness.ch

# --- Customer-facing URLs ---
# Both languages are linked from the welcome mail. Defaults point to the
# bilingual GitHub-Pages doku; override per locale if hosted elsewhere.
QUICKSTART_URL_EN=https://meintest.github.io/cc-testframework/en/quickstart/
QUICKSTART_URL_DE=https://meintest.github.io/cc-testframework/de/quickstart/

# --- Cron ---
# Random string used as Bearer token for /api/cron/* endpoints.
# Vercel sets this automatically when a cron is configured, but it
# can also be set manually for local testing.
CRON_SECRET=
